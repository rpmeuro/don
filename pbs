#include<iostream>
#include<omp.h>

using namespace std;

void swapValue(int &a,int &b) {
        int temp = a;
        a=b;
        b=temp;
}

void seqbs(int arr[],int n) {
        for(int i=0;i<n;i++) {
                bool swapped = true;
                for(int j=0;j< n-i-1;j++) {
                        if(arr[j] > arr[j+1] ) {
                                swapValue(arr[j],arr[j+1]);
                                swapped = false;
                        }
                }
        }
}

void parabs(int arr[],int n){

        for(int i=0;i<n;i+=2){
                #pragma omp parallel for
                for(int j=0;j<n-1;j+=2){
                        if(arr[j]>arr[j+1]) {
                                swapValue(arr[j],arr[j+1]);
                        }
                }

                #pragma omp parallel for
                for(int j=1;j<n-1;j++) {
                        if(arr[j]> arr[j+1]) {
                                swapValue(arr[j],arr[j+1]);
                        }
                }
        }

}

int main() {
        int n;
        cout<<"Enter number of Elements : ";
        cin>>n;

        int *arr1 = new int[n];
        int *arr2 = new int[n];

        for(int i=0;i<n;i++){
                cin>>arr1[i];
                arr2[i] =arr1[i];
        }

        double start = omp_get_wtime();
        seqbs(arr1,n);
        double end = omp_get_wtime();
        cout<<"Sequential : "<< end-start<<" sec"<<endl;
        for(int i=0;i<n;i++){
                cout<<arr1[i]<<" ";
        }

        start = omp_get_wtime();
        parabs(arr2,n);
        end = omp_get_wtime();
        cout<<"\n Parallel : "<<end-start<<" sec"<<endl;
        for(int i=0;i<n;i++){
                cout<<arr2[i]<<" ";
        }
        delete[] arr1;
        delete[] arr2;

        return 0;

}
